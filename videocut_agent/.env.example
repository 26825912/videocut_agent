# ==================== LLM API 配置 ====================
GEMINI_API_KEY=your-api-key-here
GEMINI_API_BASE=https://api.openai.com/v1

# ==================== 语音合成配置 ====================
# Fish Audio TTS (云端API)
TTS_API_URL=https://api.fish.audio/v1/tts
TTS_API_TOKEN=your-fish-audio-token

# GPT-SoVITS (本地推理，需启动服务)
# 服务地址: http://localhost:9880
# 启动方式: cd models/gpt-sovits && python api_v2.py

# ==================== 语音识别配置 ====================
# Azure Speech Services
AZURE_SERVICE_REGION=eastasia
AZURE_SERVICE_KEY=your-azure-key

# FunASR (本地推理，需启动Docker服务)
# 服务地址: http://localhost:8001
# 启动方式: docker-compose -f docker_services/docker-compose.yml up -d funasr_service

# ==================== 素材搜索配置 ====================
# Unsplash 图片搜索 (多个key用逗号分隔)
UNSPLASH_ACCESS_KEYS=your-unsplash-key-1,your-unsplash-key-2
UNSPLASH_API_URL=https://api.unsplash.com

# Pixabay 视频搜索
PIXABAY_API_KEY=your-pixabay-key
PIXABAY_API_URL=https://pixabay.com/api/videos/

# ==================== 脚本生成配置 ====================
# Dify 工作流 API
DIFY_API_KEY=your-dify-key

# 脚本生成服务
SCRIPTS_API_KEY=your-scripts-key
SCRIPTS_BASE_URL=https://difyzzc.zuzuche.com/v1/workflows/run

# AI 文案改写服务
AI_COPYWRITE_API_KEY=your-copywrite-key
AI_COPYWRITE_API_BASE_URL=https://difyzzc.zuzuche.com/v1/workflows/run

# 脚本分解服务
COPYWRITE_BASE_URL=https://difyzzc.zuzuche.com/v1/workflows/run

# ==================== 其他配置 ====================
IMAGE_SEARCH_API_KEY=
VIDEO_SEARCH_API_KEY=

# ==================== 视频处理配置 ====================
OUTPUT_DIR=./output
TEMP_DIR=./temp
DEFAULT_RESOLUTION=1080p
